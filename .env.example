# Environment Configuration Template
# Copy this file to .env and fill in actual values
# Example: cp .env.example .env

# =============================================================================
# Environment Configuration
# =============================================================================

# Flask Application Environment
# Determines the runtime environment and affects Flask middleware behavior
# Values: development, production, test
# - development: Enables verbose logging, dev-friendly error messages
# - production: Optimizes performance, uses combined log format
# - test: Used for running automated tests
FLASK_ENV=development

# Logging Level
# Controls the verbosity of Python logging output
# Values: DEBUG, INFO, WARNING, ERROR
# - DEBUG: Most verbose, includes detailed debugging information
# - INFO: Standard operational messages (recommended for production)
# - WARNING: Warning messages and above
# - ERROR: Only error messages
LOG_LEVEL=info

# =============================================================================
# Server Configuration
# =============================================================================

# Port on which the Flask server will listen
# Default: 3000
PORT=3000

# =============================================================================
# Database Configuration
# =============================================================================

# Database Host
# The hostname or IP address of the database server
# Example: localhost, 192.168.1.100, db.example.com
DB_Host=

# Database Connection String (legacy, maintained for compatibility)
# Full database connection string
# Example: mongodb://localhost:27017/myapp or postgresql://user:pass@host:5432/db
DB=

# =============================================================================
# API Configuration
# =============================================================================

# API Key for External Services
# Authentication key for external API integrations
# Keep this value secret and never commit to version control
# Example: sk_live_abc123xyz789
API_KEY=

# =============================================================================
# Application Settings
# =============================================================================

# Add additional application-specific settings below
# Example:
# CACHE_TTL=3600
# MAX_UPLOAD_SIZE=10485760
